<div class="<%= wrapper_classes %>">
  <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-accent"><%= @label %></p>
  <h2 class="text-3xl font-black text-brand-charcoal sm:text-4xl"><%= @title %></h2>
  <% if @subtitle.present? %>
    <p class="mx-auto mt-3 max-w-2xl text-base leading-7 text-brand-soft-gray"><%= @subtitle %></p>
  <% end %>
</div>
