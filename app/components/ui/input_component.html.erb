<div class="<%= @classes %>">
  <label class="app-label"><%= @label %></label>
  <div class="mt-2">
    <%= content %>
  </div>
  <% if @error.present? %>
    <p class="mt-2 text-sm text-rose-600"><%= @error %></p>
  <% elsif @hint.present? %>
    <p class="mt-2 text-xs text-slate-500"><%= @hint %></p>
  <% end %>
</div>
