<header class="absolute top-0 right-0 z-50 sm:sticky sm:inset-x-0 sm:right-auto sm:border-b sm:border-slate-200/60 sm:bg-white/80 sm:shadow-soft sm:backdrop-blur-sm" x-data="{ open: false }">
  <div class="flex items-center justify-between h-auto px-4 py-4 mx-auto max-w-7xl sm:h-16 sm:px-6 sm:py-0 lg:px-8">
    <%= link_to root_path, class: 'hidden items-center space-x-3 group sm:flex' do %>
      <%= image_tag 'logo-128.png', alt: 'DietingApp Logo', class: 'h-10 w-auto transition-transform duration-200 group-hover:scale-105' %>
      <span class="hidden bg-gradient-to-r from-brand-sage-dark to-brand-sage bg-clip-text text-xl font-bold text-transparent sm:block">DietingApp</span>
    <% end %>

    <% if current_user.present? %>
      <nav class="items-center hidden space-x-8 md:flex">
        <%= link_to diets_path, class: 'text-sm font-medium text-slate-700 hover:text-brand-navy transition-colors duration-200 flex items-center space-x-2 group' do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 transition-transform duration-200 group-hover:scale-110">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
          <span>Diety</span>
        <% end %>
        <% if Current.user.admin? %>
          <%= link_to admin_root_path, class: 'text-sm font-medium text-slate-700 hover:text-brand-navy transition-colors duration-200 flex items-center space-x-2 group' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 transition-transform duration-200 group-hover:scale-110">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v18m0-18h16.5M3.75 21h16.5M7.5 7.5h9m-9 4.5h9m-9 4.5h6" />
            </svg>
            <span>Admin</span>
          <% end %>
          <%= link_to product_categories_path, class: 'text-sm font-medium text-slate-700 hover:text-brand-navy transition-colors duration-200 flex items-center space-x-2 group' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 transition-transform duration-200 group-hover:scale-110">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
            <span>Classifications</span>
          <% end %>
          <%= link_to product_name_suggestions_path, class: 'text-sm font-medium text-slate-700 hover:text-brand-navy transition-colors duration-200 flex items-center space-x-2 group' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 transition-transform duration-200 group-hover:scale-110">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
            </svg>
            <span>Korekta nazw</span>
          <% end %>
        <% end %>
      </nav>
    <% end %>

    <div class="flex items-center space-x-4">
      <% if current_user.present? %>
        <% if shared_shopping_cart? %>
          <div class="hidden rounded-full border border-brand-mint/60 bg-brand-mint-soft px-3 py-1 text-xs font-semibold text-brand-mint-strong md:block">
            Lista wspoldzielona z <%= shopping_cart_partner_label %>
          </div>
        <% end %>
        <div class="relative hidden text-left sm:inline-block" data-controller="dropdown" data-action="click@window->dropdown#hide">
          <button type="button" 
                  class="flex items-center p-2 transition-all duration-200 rounded-full text-slate-400 bg-slate-100 hover:text-slate-600 hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-navy focus:ring-offset-2 focus:ring-offset-white" 
                  id="menu-button" 
                  aria-expanded="false" 
                  aria-haspopup="true" 
                  data-dropdown-target="button"
                  data-action="click->dropdown#toggle">
            <span class="sr-only">Open user menu</span>
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M10 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM10 8.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM11.5 15.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z" />
            </svg>
          </button>
          
          <div class="absolute right-0 z-10 hidden w-56 mt-2 origin-top-right bg-white/95 backdrop-blur-sm rounded-xl shadow-large ring-1 ring-slate-200/60 focus:outline-none animate-scale-in" 
               role="menu" 
               aria-orientation="vertical" 
               aria-labelledby="menu-button" 
               tabindex="-1" 
               data-dropdown-target="menu"
               data-transition-enter="transition ease-out duration-200"
               data-transition-enter-from="transform opacity-0 scale-95"
               data-transition-enter-to="transform opacity-100 scale-100"
               data-transition-leave="transition ease-in duration-150"
               data-transition-leave-from="transform opacity-100 scale-100"
               data-transition-leave-to="transform opacity-0 scale-95">
            <div class="py-2" role="none">
              
              <%= link_to profile_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
                Your profile
              <% end %>
              
              <%= link_to diets_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
                Diety
              <% end %>

              <%= link_to product_substitutions_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12m-4.5 4.5h18m-4.5-13.5L21 7.5m0 0L16.5 12M21 7.5H3" />
                </svg>
                Zamienniki
              <% end %>
              
              <% if Current.user.admin? %>
                <%= link_to admin_root_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v18m0-18h16.5M3.75 21h16.5M7.5 7.5h9m-9 4.5h9m-9 4.5h6" />
                  </svg>
                  Admin
                <% end %>

                <%= link_to product_categories_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                  </svg>
                  Classifications
                <% end %>

                <%= link_to product_name_suggestions_path, class: 'text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-brand-peach-soft transition-colors duration-200' do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-brand-navy">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                  </svg>
                  Korekta nazw
                <% end %>
              <% end %>
              
              <div class="my-2 border-t border-slate-200"></div>
              
              <%= button_to session_path, method: :delete, class: 'w-full text-left text-slate-700 group flex items-center px-4 py-2 text-sm hover:bg-rose-50 transition-colors duration-200' do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 transition-colors duration-200 text-slate-400 group-hover:text-rose-500">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                </svg>
                Sign out
              <% end %>
              
              <div class="my-2 border-t border-slate-200"></div>
              
              <%= render 'shared/buy_coffee' %>
            </div>
          </div>
        </div>

        <button type="button"
                class="flex items-center p-2 rounded-full text-brand-ink sm:hidden"
                @click="open = true"
                aria-haspopup="true"
                :aria-expanded="open">
          <span class="sr-only">Open menu</span>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

      <% else %>
        <%= link_to new_session_path, class: 'inline-flex items-center justify-center rounded-full bg-brand-sage-dark px-4 py-2.5 text-sm font-semibold text-white shadow-soft transition-all duration-200 hover:bg-brand-accent hover:shadow-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-sage-dark' do %>
          Log in
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if current_user.present? %>
    <%# ponytail: mobile overlay repeats the desktop dropdown links with bigger touch targets;
        not extracted to a shared partial since a third consumer would be the trigger for that %>
    <div x-show="open" x-cloak class="fixed inset-0 z-50 sm:hidden">
      <div class="absolute inset-0 bg-brand-ink/40 backdrop-blur-sm"
           @click="open = false"
           x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
           x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"></div>

      <div class="absolute inset-y-0 right-0 flex w-full max-w-xs flex-col overflow-y-auto bg-brand-warm-white shadow-large"
           x-transition:enter="transition ease-out duration-200" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
           x-transition:leave="transition ease-in duration-150" x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full">
        <div class="flex items-center justify-between px-4 py-4">
          <span class="font-serif text-lg font-bold text-brand-ink">Menu</span>
          <button type="button" class="rounded-full p-2 text-brand-ink" @click="open = false">
            <span class="sr-only">Close menu</span>
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M6 6l12 12M18 6L6 18" />
            </svg>
          </button>
        </div>

        <nav class="flex-1 px-2 py-2">
          <%= link_to profile_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            Twój profil
          <% end %>

          <%= link_to diets_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
            Diety
          <% end %>

          <%= link_to product_substitutions_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12m-4.5 4.5h18m-4.5-13.5L21 7.5m0 0L16.5 12M21 7.5H3" />
            </svg>
            Zamienniki
          <% end %>

          <% if Current.user.admin? %>
            <%= link_to admin_root_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v18m0-18h16.5M3.75 21h16.5M7.5 7.5h9m-9 4.5h9m-9 4.5h6" />
              </svg>
              Admin
            <% end %>

            <%= link_to product_categories_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
              </svg>
              Classifications
            <% end %>

            <%= link_to product_name_suggestions_path, class: 'text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-brand-peach-soft transition-colors duration-200' do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-brand-navy">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
              </svg>
              Korekta nazw
            <% end %>
          <% end %>

          <div class="my-2 border-t border-brand-ink/10"></div>

          <%= button_to session_path, method: :delete, class: 'w-full text-left text-brand-ink group flex items-center gap-3 rounded-xl px-4 py-3.5 text-base font-medium hover:bg-rose-50 transition-colors duration-200' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-ink-faint group-hover:text-rose-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
            </svg>
            Wyloguj
          <% end %>

          <div class="my-2 border-t border-brand-ink/10"></div>

          <div class="px-4 py-2">
            <%= render 'shared/buy_coffee' %>
          </div>
        </nav>
      </div>
    </div>
  <% end %>
</header>
