<div class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-slate-900">Korekta nazw produktów</h1>
    <p class="mt-1 text-sm text-slate-600">
      Niepewne dopasowania nazw wymagające zatwierdzenia. Każdy wiersz to unikalna oryginalna nazwa produktu.
    </p>
    <% if @pagy.present? && @suggestion_rows.present? %>
      <p class="mt-2 text-xs text-slate-500">Strona <%= @pagy.page %>.</p>
    <% end %>
  </div>

  <div class="space-y-3">
    <% if @suggestion_rows.blank? %>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-600">
        Brak sugestii do przejrzenia.
      </div>
    <% end %>

    <% @suggestion_rows.each do |row| %>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="grid gap-3 sm:grid-cols-[1.8fr_1fr_0.6fr_auto_auto] sm:items-center">

          <div>
            <p class="font-medium text-slate-900"><%= row.raw_name %></p>
            <p class="text-xs text-slate-500"><%= row.user_email %></p>
          </div>

          <div>
            <p class="text-sm text-slate-700"><%= row.canonical_product_name.presence || "— brak dopasowania —" %></p>
            <p class="text-xs text-slate-400"><%= row.match_type %></p>
          </div>

          <div>
            <span class="inline-flex rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">
              <%= "%.0f%%" % (row.confidence * 100) %>
            </span>
            <% if row.occurrence_count > 1 %>
              <p class="mt-1 text-xs text-slate-500"><%= row.occurrence_count %> ×</p>
            <% end %>
          </div>

          <div>
            <%= button_to "Zatwierdź",
                          product_name_suggestion_path(row.id),
                          method: :patch,
                          params: { action_type: "approve", page: @pagy&.page },
                          class: "rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500" %>
          </div>

          <div>
            <%= button_to "Odrzuć",
                          product_name_suggestion_path(row.id),
                          method: :patch,
                          params: { action_type: "reject", page: @pagy&.page },
                          class: "rounded-md bg-rose-100 px-4 py-2 text-sm font-medium text-rose-700 hover:bg-rose-200" %>
          </div>

        </div>
      </div>
    <% end %>
  </div>

  <% if @pagy.present? && @pagy.last.to_i > 1 %>
    <div class="mt-8 flex items-center justify-center text-sm text-slate-700">
      <%== pagy_series_nav(@pagy) %>
    </div>
  <% end %>
</div>
