<%= turbo_stream_from @shopping_cart %>
<div class="mb-6">
  <%= render Ui::SectionHeaderComponent.new(label: "Shopping", title: "Lista zakupow", subtitle: "Produkty z diety i Twoje wlasne pozycje w jednym miejscu.") %>
</div>
<%= render 'shopping_cart', shopping_cart: @shopping_cart %>

<!-- Bottom Navigation -->
<div class="fixed bottom-0 left-0 right-0 z-50 flex justify-around border-t border-slate-200 bg-white/95 px-4 py-4 shadow-md backdrop-blur-sm" style="transform: translateZ(0); -webkit-transform: translateZ(0); backface-visibility: hidden; -webkit-backface-visibility: hidden; will-change: transform; padding-bottom: calc(1rem + env(safe-area-inset-bottom));">
  <%= link_to '🥗 Twoja dieta', diet_set_plans_path, class: 'font-semibold text-brand-soft-gray' %>
  <%= link_to '🛒 Lista zakupów', shopping_cart_path, class: 'font-semibold text-brand-sage-dark' %>
</div>
