<%= turbo_stream_from @shopping_cart %>

<!-- Header -->
<div class="mb-3.5 flex items-center gap-3">
  <%= link_to diet_set_plans_path, class: "shrink-0 text-brand-ink" do %>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4 L6 12 L14 20" /></svg>
  <% end %>
  <h1 class="flex-1 font-serif text-2xl font-extrabold tracking-tight text-brand-ink">Lista zakupów</h1>
  <button type="button" class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-brand-ink/10 bg-white text-brand-ink">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="6" /><path d="M14.5 14.5 L20 20" /></svg>
  </button>
</div>

<%= render 'shopping_cart', shopping_cart: @shopping_cart %>

<div id="undo_toast"></div>
