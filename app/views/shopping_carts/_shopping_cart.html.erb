<turbo-frame id="shopping_cart">
  <div class="mb-6 rounded-2xl border border-emerald-100 bg-emerald-50 p-4">
    <p class="text-sm font-semibold text-brand-sage-dark">Lista zakupow</p>
    <% if shopping_cart.shared? %>
      <p class="mt-1 text-sm text-brand-sage-dark">
        Wspolna lista:
        <%= shopping_cart.member_users.map { |user| shopping_cart_member_label(user) }.join(' + ') %>
      </p>
    <% else %>
      <p class="mt-1 text-sm text-brand-sage-dark">To jest Twoja prywatna lista zakupow.</p>
    <% end %>
  </div>

  <% diet_items_empty = shopping_cart.shopping_cart_items.empty? %>
  <% custom_items_empty = shopping_cart.custom_cart_items.empty? %>

  <% if diet_items_empty && custom_items_empty %>
    <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center text-brand-soft-gray">
      Koszyk jest pusty.
    </div>
  <% end %>

  <div class="mb-6">
    <h2 class="mb-2 text-lg font-bold text-brand-charcoal">Własne produkty</h2>
    <div id="custom_cart_item_form_errors"></div>
    <%= form_with model: CustomCartItem.new, url: custom_cart_items_path, class: "custom-cart-form mb-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-soft" do |f| %>
      <div class="flex flex-col gap-3">
          <%= f.text_field :name, placeholder: "np. ręcznik papierowy", class: "custom-cart-input app-input min-h-[48px] w-full text-base", required: true %>
        <div class="flex flex-row items-end justify-between gap-2">
          <div class="flex flex-row items-end gap-2">
            <%= f.number_field :quantity, value: 1, min: 1, class: "custom-cart-input app-input min-h-[48px] w-20 shrink-0 text-base" %>
            <%= f.text_field :unit, placeholder: "szt", value: "szt", class: "custom-cart-input app-input min-h-[48px] w-24 shrink-0 text-base" %>
          </div>
          <%= f.submit "Dodaj", class: "custom-cart-submit min-h-[48px] shrink-0 rounded-full bg-brand-sage-dark px-5 py-3 text-base font-semibold text-white hover:bg-brand-accent" %>
        </div>
      </div>
    <% end %>
    <% if custom_items_empty %>
      <p class="text-sm text-brand-soft-gray">Dodaj produkty spoza diety (np. ręcznik papierowy, środki czystości).</p>
    <% else %>
      <ul class="space-y-2">
        <% shopping_cart.custom_cart_items.order(:created_at).each do |item| %>
          <li id="<%= dom_id(item) %>" class="flex items-center justify-between rounded-2xl border border-amber-200 bg-amber-50 p-4 shadow-soft">
            <div>
              <p class="text-base font-semibold"><%= item.name %></p>
              <p class="text-sm text-brand-soft-gray"><%= item.quantity %> <%= item.unit.presence || 'szt' %></p>
            </div>
            <%= button_to "Usuń", custom_cart_item_path(item), method: :delete,
                  form: { data: { turbo_stream: true } },
                  class: "rounded-full bg-rose-500 px-3 py-1 text-xs text-white hover:bg-rose-600" %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <% unless diet_items_empty %>
    <% shopping_cart.group_and_sum_by_cart_items.each do |group| %>
      <div id="category_<%= group[:category]&.name&.parameterize || 'inne' %>">
        <div class="mb-6">
          <h2 class="mb-2 text-lg font-bold text-brand-charcoal"><%= group[:category]&.name || 'Inne' %></h2>
          <ul class="space-y-2">
            <% group[:products].each do |product_group| %>
              <li id="<%= shopping_cart_item_id_for(group[:category], product_group[:name]) %>" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-4 shadow-soft">
                <div>
                  <p class="text-base font-semibold"><%= product_group[:name] %></p>
                  <% if product_group[:aggregated_ingredient_measures].present? %>
                    <p class="text-sm text-brand-soft-gray">
                      <%= t('shopping_cart.measurements_label') %>:
                      <% product_group[:aggregated_ingredient_measures].each_with_index do |measurement, idx| %>
                        <% amount = (measurement[:amount] || 0).to_f %>
                        <% unit_key = unit_key_for_i18n(measurement[:unit]) %>
                        <% unit_str = unit_key.present? ? I18n.t("units.#{unit_key}", count: measurement[:amount], default: measurement[:unit].to_s) : measurement[:unit].to_s %>
                        <%= " " if idx > 0 %>
                        <% if amount.zero? %>
                          <%= unit_str %>
                        <% else %>
                          <%= amount.round(2) %> <%= unit_str %>
                        <% end %>
                      <% end %>
                    </p>
                  <% end %>
                </div>
                <%= button_to t('shopping_cart.remove'), shopping_cart_item_path(product_group[:product]), method: :delete,
                      form: { data: { turbo_stream: true } },
                      class: "rounded-full bg-rose-500 px-3 py-1 text-xs text-white hover:bg-rose-600" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

  <% end %>

  <div class="mb-12"></div>
</turbo-frame>
