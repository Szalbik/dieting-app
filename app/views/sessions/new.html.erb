<div class="mx-auto w-full max-w-md">
  <%= render Ui::CardComponent.new(padding: :lg, classes: "shadow-xl shadow-brand-sage/10") do %>
    <div class="text-center">
      <%= link_to root_path, class: "inline-flex justify-center" do %>
        <%= image_tag "logo-128.png", alt: "DietingApp Logo", class: "h-14 w-auto" %>
      <% end %>
      <p class="mt-6 text-xs font-semibold uppercase tracking-[0.18em] text-brand-sage-dark/80">Welcome back</p>
      <h1 class="mt-2 text-3xl font-black text-brand-charcoal sm:text-4xl">Sign in to your account</h1>
      <p class="mt-3 text-sm text-brand-soft-gray">Continue your nutrition journey with your saved plans and shopping lists.</p>
    </div>

    <%= form_with url: session_path, data: { turbo: false }, class: "mt-8 space-y-4" do |form| %>
      <%= render Ui::InputComponent.new(label: "Email address") do %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "app-input", placeholder: "Enter your email" %>
      <% end %>

      <%= render Ui::InputComponent.new(label: "Password") do %>
        <div class="mb-2 text-right text-xs">
          <%= link_to "Forgot password?", new_password_path, class: "font-semibold text-brand-sage-dark hover:text-brand-accent" %>
        </div>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "app-input", placeholder: "Enter your password" %>
      <% end %>

      <%= render Ui::ButtonComponent.new(type: "submit", variant: :primary, size: :lg, full_width: true).with_content("Sign in") %>
    <% end %>

    <p class="mt-7 text-center text-sm text-brand-soft-gray">
      Don't have an account?
      <%= link_to "Start your free trial", new_registration_path, class: "font-semibold text-brand-sage-dark hover:text-brand-accent" %>
    </p>
  <% end %>
</div>
