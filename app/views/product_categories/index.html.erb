<div class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-slate-900">Klasyfikacja produktów</h1>
    <p class="mt-1 text-sm text-slate-600">
      Produkty bez potwierdzonej kategorii. Każdy wiersz to unikalna nazwa produktu.
    </p>
  </div>

  <div class="space-y-3">
    <% if @classification_rows.blank? %>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-600">
        Brak produktów do sklasyfikowania.
      </div>
    <% end %>

    <% @classification_rows.each do |row| %>
      <%= form_with url: product_category_path(row[:id]), method: :patch, class: "rounded-lg border border-slate-200 bg-white p-4" do |form| %>
        <%= hidden_field_tag :product_name, row[:name] %>
        <div class="grid gap-3 sm:grid-cols-[1.8fr_0.8fr_1.2fr_auto] sm:items-center">
          <div>
            <p class="font-medium text-slate-900"><%= row[:name] %></p>
            <% if row[:count] > 1 %>
              <p class="text-xs text-slate-500">Powtórzenia: <%= row[:count] %></p>
            <% end %>
          </div>

          <div>
            <span class="inline-flex rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">
              <%= row[:count] %> szt.
            </span>
          </div>

          <div>
            <%= form.select :category_id,
                            Category.order(:name).pluck(:name, :id),
                            { selected: row[:category_id] },
                            { name: "product_category[category_id]", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" } %>
          </div>

          <div>
            <%= form.submit "Zapisz", class: "rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
