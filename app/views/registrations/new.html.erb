<div class="mx-auto w-full max-w-md">
  <%= render Ui::CardComponent.new(padding: :lg, classes: "shadow-xl shadow-brand-sage/10") do %>
    <div class="text-center">
      <%= link_to root_path, class: "inline-flex justify-center" do %>
        <%= image_tag "logo-128.png", alt: "DietingApp Logo", class: "h-14 w-auto" %>
      <% end %>
      <p class="mt-6 text-xs font-semibold uppercase tracking-[0.18em] text-brand-sage-dark/80">Get started</p>
      <h1 class="mt-2 text-3xl font-black text-brand-charcoal sm:text-4xl">Create your account</h1>
      <p class="mt-3 text-sm text-brand-soft-gray">Build your personalized nutrition routine in less than a minute.</p>
    </div>

    <%= form_with model: @user, url: registrations_path, data: { turbo: false }, class: "mt-8 space-y-4" do |form| %>
      <% if form.object.errors.any? %>
        <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-700">
          <ul class="list-disc space-y-1 pl-4">
            <% form.object.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render Ui::InputComponent.new(label: "Email address") do %>
        <%= form.email_field :email_address, class: "app-input", placeholder: "name@example.com" %>
      <% end %>

      <%= render Ui::InputComponent.new(label: "Password") do %>
        <%= form.password_field :password, class: "app-input" %>
      <% end %>

      <%= render Ui::InputComponent.new(label: "Confirm password") do %>
        <%= form.password_field :password_confirmation, class: "app-input" %>
      <% end %>

      <%= render Ui::ButtonComponent.new(type: "submit", variant: :primary, size: :lg, full_width: true).with_content("Create account") %>
    <% end %>

    <p class="mt-7 text-center text-sm text-brand-soft-gray">
      Already have an account?
      <%= link_to "Sign in", new_session_path, class: "font-semibold text-brand-sage-dark hover:text-brand-accent" %>
    </p>
  <% end %>
</div>
