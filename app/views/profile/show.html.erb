<div class="flex items-start w-full px-4 py-10 mx-auto max-w-7xl gap-x-8 sm:px-6 lg:px-8">
  <main class="flex-1">
    <div class="mb-6">
      <h2 class="text-lg font-semibold">Your Email: <span class="font-mono text-indigo-700"><%= Current.user.email_address %></span></h2>
    </div>
    <div class="p-6 mb-8 bg-white border border-gray-200 shadow-sm rounded-2xl">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <h3 class="text-base font-semibold text-gray-900">Wspolna lista zakupow</h3>
          <% if @shopping_cart_partner.present? %>
            <p class="mt-2 text-sm text-gray-700">
              Twoja lista zakupow jest polaczona z kontem
              <span class="font-semibold"><%= @shopping_cart_partner.email_address %></span>.
            </p>
          <% else %>
            <p class="mt-2 text-sm text-gray-700">
              Wyslij zaproszenie po adresie e-mail. Po akceptacji obie osoby beda edytowaly jedna liste zakupow.
            </p>
          <% end %>
        </div>

        <% if @shopping_cart_partner.present? %>
          <% current_invitation = Current.user.accepted_shopping_cart_invitation %>
          <%= button_to "Rozlacz wspolna liste",
                revoke_shopping_cart_invitation_path(current_invitation),
                method: :patch,
                class: "rounded-lg bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-500" %>
        <% else %>
          <%= form_with url: shopping_cart_invitations_path, method: :post, class: "w-full max-w-md" do |f| %>
            <label class="block text-sm font-medium text-gray-900">Wyślij zaproszenie</label>
            <div class="flex gap-3 mt-2">
              <%= email_field_tag :email_address, nil, placeholder: "kasia@example.com", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900" %>
              <%= f.submit "Wyślij", class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500" %>
            </div>
          <% end %>
        <% end %>
      </div>

      <% if @received_shopping_cart_invitations.any? %>
        <div class="mt-6">
          <h4 class="text-sm font-semibold text-gray-900">Oczekujace zaproszenia do Ciebie</h4>
          <div class="mt-3 space-y-3">
            <% @received_shopping_cart_invitations.each do |invitation| %>
              <div class="flex flex-col gap-3 rounded-xl border border-gray-200 p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= invitation.inviter.email_address %></p>
                  <p class="text-xs text-gray-500">Status: <%= invitation.status %></p>
                </div>
                <div class="flex gap-2">
                  <%= button_to "Akceptuj", accept_shopping_cart_invitation_path(invitation), method: :patch, class: "rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-500" %>
                  <%= button_to "Odrzuc", reject_shopping_cart_invitation_path(invitation), method: :patch, class: "rounded-lg bg-gray-200 px-3 py-2 text-xs font-semibold text-gray-800 hover:bg-gray-300" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @sent_shopping_cart_invitations.any? %>
        <div class="mt-6">
          <h4 class="text-sm font-semibold text-gray-900">Wyslane oczekujace zaproszenia</h4>
          <div class="mt-3 space-y-3">
            <% @sent_shopping_cart_invitations.each do |invitation| %>
              <div class="flex flex-col gap-3 rounded-xl border border-gray-200 p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= invitation.invitee.email_address %></p>
                  <p class="text-xs text-gray-500">Status: <%= invitation.status %></p>
                </div>
                <%= button_to "Odwolaj", revoke_shopping_cart_invitation_path(invitation), method: :patch, class: "rounded-lg bg-rose-600 px-3 py-2 text-xs font-semibold text-white hover:bg-rose-500" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @shopping_cart_invitation_history.any? %>
        <div class="mt-6">
          <h4 class="text-sm font-semibold text-gray-900">Historia zaproszen</h4>
          <div class="mt-3 space-y-2">
            <% @shopping_cart_invitation_history.each do |invitation| %>
              <div class="rounded-xl border border-gray-100 bg-gray-50 px-4 py-3 text-sm text-gray-700">
                <span class="font-medium"><%= invitation.inviter.email_address %></span>
                <span class="text-gray-400">→</span>
                <span class="font-medium"><%= invitation.invitee.email_address %></span>
                <span class="ml-2 rounded-full bg-white px-2 py-1 text-xs font-semibold text-gray-600"><%= invitation.status %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <!-- Main area -->
    <div class="flow-root mt-2">  
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">  
        <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">  
          <div class="relative">  

            <%= form_with model: Current.user, url: user_path(Current.user), method: :patch do |f| %>
              <div class="space-y-12">
                <div class="pb-12 border-b border-gray-900/10">
                  <h2 class="text-base font-semibold leading-7 text-gray-900">Personal Information</h2>
                  <p class="mt-1 text-sm leading-6 text-gray-600">Use a permanent address where you can receive mail.</p>

                  <div class="grid grid-cols-1 mt-10 gap-x-6 gap-y-8 sm:grid-cols-6">
                    <div class="sm:col-span-3">
                      <label for="first-name" class="block text-sm font-medium leading-6 text-gray-900">First name</label>
                      <div class="mt-2">
                        <%= f.text_field :first_name, class: 'block px-2 w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6' %>
                      </div>
                    </div>

                    <div class="sm:col-span-4">
                      <label for="email" class="block text-sm font-medium leading-6 text-gray-900">Email address</label>
                      <div class="mt-2">
                        <%= f.email_field :email_address, class: 'block w-full px-2 rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6'  %>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="flex items-center justify-end mt-6 gap-x-6">
                  <button type="button" class="text-sm font-semibold leading-6 text-gray-900">Cancel</button>
                  <button type="submit" class="px-3 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-md shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Save</button>
                </div>
              </div>
            <% end %>
            
          </div> 
        </div>  
      </div>  
    </div>   
  </main>
</div>
