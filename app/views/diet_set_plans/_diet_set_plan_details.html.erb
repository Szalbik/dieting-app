<!-- Meal Plan Details -->
<div class="mt-6 space-y-4">
  <%# Assume that diet_set_plan.diet.diet_sets.first is the chosen set %>
  <h3 class="text-center text-2xl font-black">🥗 <%= @diet_set_plan.derived_name_from_meal %></h3>
  <% if @diet_set_plan.meal_plans.any? %>
    <%# Calculate daily totals %>
    <% daily_totals = @diet_set_plan.meal_plans.sum { |mp| mp.kcal || 0 } %>
    <% daily_protein = @diet_set_plan.meal_plans.sum { |mp| mp.protein || 0 } %>
    <% daily_fat = @diet_set_plan.meal_plans.sum { |mp| mp.fat || 0 } %>
    <% daily_carbs = @diet_set_plan.meal_plans.sum { |mp| mp.carbs || 0 } %>
    <% if daily_totals > 0 || daily_protein > 0 || daily_fat > 0 || daily_carbs > 0 %>
      <div class="mb-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
        <h4 class="mb-2 text-sm font-semibold text-center text-green-800">📊 Podsumowanie dnia</h4>
        <div class="flex justify-center gap-4 text-sm">
          <div class="text-center">
            <div class="font-bold text-green-700"><%= daily_totals.round %></div>
            <div class="text-xs text-green-600">kcal</div>
          </div>
          <div class="text-center">
            <div class="font-bold text-green-700"><%= daily_protein.round(1) %></div>
            <div class="text-xs text-green-600">g białka</div>
          </div>
          <div class="text-center">
            <div class="font-bold text-green-700"><%= daily_fat.round(1) %></div>
            <div class="text-xs text-green-600">g tłuszczu</div>
          </div>
          <div class="text-center">
            <div class="font-bold text-green-700"><%= daily_carbs.round(1) %></div>
            <div class="text-xs text-green-600">g węglowodanów</div>
          </div>
        </div>
      </div>
    <% end %>
    <% @diet_set_plan.meal_plans.each do |meal_plan| %>
      <!-- Each meal card is clickable and toggles its details using our Stimulus controller -->
      <div class="cursor-pointer rounded-2xl border border-slate-200 bg-white p-4 shadow-soft transition hover:shadow-medium"
            data-controller="toggle-meal"
            data-action="click->toggle-meal#toggle">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-brand-charcoal"><%= meal_plan.name %></h3>
            <span class="text-sm text-brand-soft-gray"><%= meal_time_for(meal_plan) %></span>
            <% if meal_plan.kcal.present? || meal_plan.protein.present? || meal_plan.fat.present? || meal_plan.carbs.present? %>
              <div class="mt-2 flex gap-3 text-xs text-brand-soft-gray">
                <% if meal_plan.kcal.present? %>
                  <span><strong><%= meal_plan.kcal %></strong> kcal</span>
                <% end %>
                <% if meal_plan.protein.present? %>
                  <span><strong><%= meal_plan.protein.round(1) %></strong>g białka</span>
                <% end %>
                <% if meal_plan.fat.present? %>
                  <span><strong><%= meal_plan.fat.round(1) %></strong>g tłuszczu</span>
                <% end %>
                <% if meal_plan.carbs.present? %>
                  <span><strong><%= meal_plan.carbs.round(1) %></strong>g węglowodanów</span>
                <% end %>
              </div>
            <% end %>
          </div>
          <div id="<%= dom_id(meal_plan, :shopping_bag) %>">
            <%= render partial: "diet_set_plans/shopping_bag_icon", locals: { meal_plan: meal_plan } %>
          </div>
        </div>
        <!-- Details: instructions (steps) and ingredients (initially hidden) -->
        <div data-toggle-meal-target="toggle" data-toggle-meal-animation-value="slide" class="hidden mt-2 overflow-hidden">
          <% if meal_plan.instructions.present? %>
            <div class="instruction-parts">
              <%= format_meal_instructions(meal_plan.instructions) %>
            </div>
          <% end %>
          <% if meal_plan.products.any? %>
            <div class="<%= 'mt-6 border-t border-slate-200 pt-4' if meal_plan.instructions.present? %>">
              <h4 class="mb-3 text-sm font-semibold text-slate-700">Składniki</h4>
              <ul class="list-disc">
                <% meal_plan.products.each do |product| %>
                  <%= render "diet_set_plans/ingredient_row", meal_plan: meal_plan, product: product %>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="mt-6 text-center text-brand-soft-gray">Brak posiłków dla wybranego zestawu.</p>
  <% end %>
  <div class="mt-4 mb-12 space-y-2 text-center" data-controller="diet-swap">
    <div class="flex items-center justify-center space-x-4">
      <%= link_to "Przypisz nowy zestaw", diet_set_plans_path(reassign: true, date: params['date']), class: "text-xs text-brand-soft-gray hover:text-brand-sage-dark hover:underline" %>
      <span class="text-gray-300">|</span>
      <button type="button"
              class="text-xs text-brand-soft-gray hover:text-brand-sage-dark hover:underline"
              data-action="click->diet-swap#toggle">
        Zamień z innym dniem
      </button>
    </div>

    <% weekday_names = %w[niedziela poniedziałek wtorek środa czwartek piątek sobota] %>
    <div data-diet-swap-target="picker" class="hidden mt-4 text-left">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-soft">
        <h4 class="text-sm font-semibold text-brand-charcoal mb-3">Zamień z:</h4>
        <div class="space-y-2">
          <% ((Date.current - 1.day)..(Date.current + 5.days)).each do |d| %>
            <% next if d.to_s == @date.to_s %>
            <% other_plan = Current.user.diet_set_plans.where(date: d).order(created_at: :desc).first %>
            <div class="flex items-center justify-between rounded-xl border border-slate-100 bg-slate-50 px-3 py-2.5">
              <div class="min-w-0 flex-1">
                <span class="text-sm font-semibold text-brand-charcoal capitalize"><%= weekday_names[d.wday] %> <%= d.strftime('%d.%m') %></span>
                <% if other_plan %>
                  <p class="truncate text-xs text-brand-soft-gray"><%= other_plan.derived_name_from_meal %></p>
                <% else %>
                  <p class="text-xs italic text-brand-soft-gray">Brak diety</p>
                <% end %>
              </div>
              <%= button_to "Zamień", swap_diet_set_plans_path,
                    params: { current_date: @date, target_date: d.to_s },
                    method: :post,
                    class: "ml-3 shrink-0 rounded-full bg-brand-sage-dark px-3 py-1.5 text-xs font-semibold text-white hover:bg-brand-accent" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
