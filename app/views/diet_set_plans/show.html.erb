<!-- app/views/diet_set_plans/show.html.erb -->

<div>
  <% if Current.user.shopping_cart.shared? %>
    <div class="mx-auto mb-4 rounded-2xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
      Lista zakupow jest wspoldzielona z
      <span class="font-semibold"><%= Current.user.shopping_cart_partner&.first_name.presence || Current.user.shopping_cart_partner&.email_address %></span>.
    </div>
  <% end %>

  <div class="mx-auto app-section" id="date_picker">
      <%= render Ui::SectionHeaderComponent.new(label: "Dashboard", title: "Twoj plan dnia", subtitle: "Wybierz dzien i zarzadzaj posilkami.", classes: "mb-4") %>
      <%= render "date_picker" %>
  </div>

  <div id="diet_set_plan_details">
      <% if @diet_set_plan.meals.empty? %>
          <%= render 'diet_form', locals: { diet_set_plan: @diet_set_plan } %>
      <% else %>
          <%= render 'diet_set_plan_details', locals: { diet_set_plan: @diet_set_plan } %>
      <% end %>
  </div>
</div>

<!-- Bottom Navigation -->
<div class="fixed bottom-0 left-0 right-0 z-50 flex justify-around border-t border-slate-200 bg-white/95 px-4 py-4 shadow-md backdrop-blur-sm" style="transform: translateZ(0); -webkit-transform: translateZ(0); backface-visibility: hidden; -webkit-backface-visibility: hidden; will-change: transform; padding-bottom: calc(1rem + env(safe-area-inset-bottom));">
    <%= link_to '🥗 Twoja dieta', diet_set_plans_path, class: 'font-semibold text-brand-sage-dark' %>
    <%= link_to shopping_cart_path, class: 'text-brand-soft-gray text-center' do %>
      <span>🛒 Lista zakupów</span>
      <% if Current.user.shopping_cart.shared? %>
        <span class="block text-[10px] text-brand-sage-dark">wspoldzielona</span>
      <% end %>
    <% end %>
</div>
