<!-- app/views/diet_set_plans/show.html.erb -->
<% display_date = (Date.parse(@date.to_s) rescue Date.current) %>
<% pl_days = %w[Niedziela Poniedziałek Wtorek Środa Czwartek Piątek Sobota] %>
<% pl_months = %w[stycznia lutego marca kwietnia maja czerwca lipca sierpnia września października listopada grudnia] %>

<div class="relative isolate overflow-hidden pb-4">
  <div class="watercolor absolute -top-12 -right-20 -z-10 h-52 w-80 rounded-full"></div>
  <% if Current.user.shopping_cart.shared? %>
    <div class="mb-4 rounded-2xl border border-brand-sky/60 bg-brand-sky-soft px-4 py-3 text-sm text-brand-sky-strong">
      Lista zakupow jest wspoldzielona z
      <span class="font-semibold"><%= Current.user.shopping_cart_partner&.first_name.presence || Current.user.shopping_cart_partner&.email_address %></span>.
    </div>
  <% end %>

  <!-- Header -->
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <h1 class="font-serif text-[26px] font-extrabold leading-tight tracking-tight text-brand-ink">Twój plan dnia</h1>
      <p class="mt-1 text-sm text-brand-ink-soft"><%= pl_days[display_date.wday] %>, <%= display_date.day %> <%= pl_months[display_date.month - 1] %></p>
    </div>
    <%= link_to profile_path, class: "grid h-10 w-10 shrink-0 place-items-center rounded-full border border-brand-ink/10 bg-white" do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-brand-ink"><circle cx="12" cy="8" r="3.5" /><path d="M5 21 C 5 16 8 14 12 14 C 16 14 19 16 19 21" /></svg>
    <% end %>
  </div>

  <!-- Day strip -->
  <div id="date_picker" class="mt-4">
    <%= render "date_picker" %>
  </div>

  <div id="diet_set_plan_details">
    <% if @diet_set_plan.meals.empty? %>
      <%= render 'diet_form', locals: { diet_set_plan: @diet_set_plan } %>
    <% else %>
      <%= render 'diet_set_plan_details', locals: { diet_set_plan: @diet_set_plan } %>
    <% end %>
  </div>
</div>
