<%= turbo_stream.replace "shopping_cart", method: :morph do %>
  <%= render "shopping_carts/shopping_cart", shopping_cart: Current.user.shopping_cart %>
<% end %>

<%= turbo_stream.update "undo_toast" do %>
  <div data-controller="toast" data-toast-timeout-value="8000"
       class="fixed bottom-24 left-4 right-4 z-[60] mx-auto max-w-md rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-lg transition-all duration-300 opacity-0 translate-y-4">
    <div class="flex items-center justify-between gap-3">
      <p class="text-sm text-brand-charcoal">
        Usunięto <span class="font-semibold"><%= @removed_product_name %></span>
      </p>
      <%= button_to "Cofnij", undo_shopping_cart_items_path,
            method: :post,
            form: { data: { turbo_stream: true } },
            class: "shrink-0 rounded-full bg-brand-sage-dark px-4 py-1.5 text-xs font-semibold text-white hover:bg-brand-accent" %>
    </div>
  </div>
<% end %>
