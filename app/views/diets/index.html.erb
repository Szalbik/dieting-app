<div class="space-y-8">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <%= render Ui::SectionHeaderComponent.new(label: "Planer", title: "Twoje diety", subtitle: "Wybierz, którą dietę chcesz teraz stosować.") %>
    <span class="hidden sm:block">
      <%= render(Ui::ButtonComponent.new(href: new_diet_path).with_content("Dodaj dietę")) %>
    </span>
  </div>

  <%= render Ui::CardComponent.new(padding: :sm) do %>
      <div class="hidden sm:block">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
            <table class="min-w-full divide-y divide-slate-200">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-0">Name</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Sets number</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Active</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Date</th>
                  <th scope="col" class="sticky top-0 z-10 border-b border-slate-200 bg-white/80 backdrop-blur-sm py-3.5 pl-3 pr-4 sm:pr-6 lg:pr-8">
                    <span class="sr-only">Edit</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                <% @diets.each do |diet| %>
                  <tr class="transition-colors duration-200 hover:bg-slate-50/50" id="diet_row_<%= diet.id %>">
                    <td class="py-4 pl-4 pr-3 text-sm font-medium text-slate-900 whitespace-nowrap sm:pl-0">
                      <%= diet.name %>
                    </td>
                    <td class="px-3 py-4 text-sm text-slate-500 whitespace-nowrap">
                      <%= diet.diet_sets.count %>
                    </td>
                    <td class="px-3 py-4 text-sm text-slate-500 whitespace-nowrap" id="diet_toggle_<%= diet.id %>">
                      <%= render partial: 'diets/toggle_button', locals: { diet: diet } %>
                    </td>
                    <td class="px-3 py-4 text-sm text-slate-500 whitespace-nowrap">
                      <%= diet.created_at.strftime("%B %d, %Y") %>
                    </td>
                    <td class="relative py-4 pl-3 pr-4 text-sm font-medium text-right border-b border-slate-200 whitespace-nowrap sm:pr-8 lg:pr-8">
                      <% if diet.pdf.attached? %>
                        <%= link_to 'Preview pdf', url_for(diet.pdf), target: '_blank', class: 'text-brand-navy hover:text-brand-navy-strong transition-colors duration-200' %>
                        |
                        <%= button_to 'Przeparsuj ponownie', reparse_diet_path(diet), method: :post, form_class: 'inline-block', data: { confirm: 'Obecne zestawy i posiłki zostaną usunięte i odtworzone z PDF. Kontynuować?' }, class: 'text-brand-navy hover:text-brand-navy-strong transition-colors duration-200' %>
                        |
                      <% end %>
                      <%= link_to 'Edit', edit_diet_path(diet), class: 'text-brand-navy hover:text-brand-navy-strong transition-colors duration-200' %>
                      |
                      <%= button_to 'Delete', diet_path(diet.id), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-rose-600 hover:text-rose-700 transition-colors duration-200' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="mt-6 sm:hidden" data-controller="tabs">
        <%# Aktywne / Zakończone segmented tabs ("zakończone" = nieaktywne) %>
        <div class="mb-4 flex rounded-full bg-brand-paper p-1">
          <% [["aktywne", "Aktywne"], ["zakonczone", "Zakończone"]].each_with_index do |(val, label), i| %>
            <button type="button" data-tabs-target="pill" data-tab-value="<%= val %>" data-action="tabs#select" aria-selected="<%= i.zero? %>"
                    class="flex-1 rounded-full py-2 text-sm font-semibold text-brand-ink-soft aria-selected:bg-brand-navy aria-selected:text-white">
              <%= label %>
            </button>
          <% end %>
        </div>

        <div class="space-y-3">
          <% @diets.each do |diet| %>
            <div data-tabs-target="panel" data-tab-value="<%= diet.active? ? 'aktywne' : 'zakonczone' %>"
                 id="diet_card_mobile_<%= diet.id %>">
              <%= render Ui::CardComponent.new(tint: diet.active? ? :peach : nil, padding: :sm) do %>
                <div class="flex items-start gap-3">
                  <div class="foodtile foodtile-<%= diet_tile_tint_for(diet) %> h-11 w-11 text-xl"><%= diet_glyph_for(diet) %></div>
                  <div class="min-w-0 flex-1">
                    <h2 class="truncate font-semibold text-brand-ink"><%= diet.name %></h2>
                    <p class="text-xs text-brand-ink-soft"><%= diet.diet_sets.count %> zestawów · <%= diet.created_at.strftime("%d.%m.%Y") %></p>
                  </div>
                  <span id="diet_toggle_mobile_<%= diet.id %>" class="shrink-0">
                    <%= render partial: 'diets/toggle_button', locals: { diet: diet } %>
                  </span>
                </div>
                <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-brand-ink/10 pt-3 text-sm">
                  <%= link_to 'Edytuj', edit_diet_path(diet), class: 'text-brand-navy hover:text-brand-navy-strong font-medium' %>
                  <% if diet.pdf.attached? %>
                    <%= link_to 'Podgląd PDF', url_for(diet.pdf), target: '_blank', class: 'text-brand-navy hover:text-brand-navy-strong font-medium' %>
                    <%= button_to 'Przeparsuj', reparse_diet_path(diet), method: :post, data: { confirm: 'Obecne zestawy i posiłki zostaną usunięte i odtworzone z PDF. Kontynuować?' }, form_class: 'inline-block', class: 'text-brand-navy hover:text-brand-navy-strong font-medium' %>
                  <% end %>
                  <%= button_to 'Usuń', diet_path(diet.id), method: :delete, data: { confirm: 'Are you sure?' }, form_class: 'inline-block ml-auto', class: 'text-rose-600 hover:text-rose-700 font-medium' %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%= link_to new_diet_path, class: "mt-4 flex items-center justify-center gap-1.5 rounded-2xl border-[1.5px] border-dashed border-brand-sky-strong bg-brand-sky-soft py-3.5 text-sm font-semibold text-brand-sky-strong" do %>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 4 V20" /><path d="M4 12 H20" /></svg>
          Dodaj dietę
        <% end %>
      </div>
  <% end %>
</div>
